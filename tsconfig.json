{
  "compilerOptions": {
    "baseUrl": "./",
    "rootDir": "./",
    "outDir": "dist",
    "module": "CommonJS",
    "target": "ES2019",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "strict": true,
    "paths": {
      "@controllers/*": ["src/presentation/controllers/*"],
      "@domain/*": ["src/domain/*"],
      "@models/*": ["src/domain/models/*"],
      "@usecases/*": ["src/domain/usecases/*"],
      "@utils/*": ["src/utils/*"],
      "@data/*": ["src/data/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}