{
  "compilerOptions": {
    "baseUrl": "./",
    "rootDir": "./",
    "outDir": "dist",
    "module": "CommonJS",
    "target": "ES2019",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "strict": true,
    "paths": {
      "@controllers/*": ["src/presentation/controllers/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}