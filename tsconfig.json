{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "target": "ES2019",
    "module": "CommonJS",
    "allowJs": true,
    "esModuleInterop": true,
    "removeComments": true,
    "skipLibCheck": true,
    "paths": {
      "@/": ["./src"]
    },
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}